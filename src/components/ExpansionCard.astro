---
interface PriceEntry {
  name: string;
  market?: number;
  low?: number;
  updatedAt?: string;
  tcgplayerUrl?: string;
}

interface Props {
  href: string;
  slug: string;
  nombre: string;
  codigo: string;
  serie: string;
  fechaLanzamiento: Date;
  totalCartas: number;
  descripcion: string;
  color?: string;
  cartaDestacada?: string;
  cartaDestacadaAlt?: string;
  price?: PriceEntry;
}

const {
  href,
  nombre,
  codigo,
  serie,
  fechaLanzamiento,
  totalCartas,
  descripcion,
  color = '#ffcb05',
  cartaDestacada,
  cartaDestacadaAlt,
  price,
} = Astro.props;

const fecha = fechaLanzamiento.toLocaleDateString('es-CO', {
  year: 'numeric',
  month: 'short',
});

const fmtUSD = (n?: number) =>
  typeof n === 'number'
    ? new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(n)
    : '—';

const setApiId = cartaDestacada?.match(/pokemontcg\.io\/([^/]+)\//)?.[1];
const pkmnggUrl = setApiId ? `https://pkmn.gg/sets/${setApiId}` : null;
const tcgplayerUrl = price?.tcgplayerUrl;
---

<article class="card-hover group relative rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-card)] overflow-hidden">
  {cartaDestacada && (
    <div
      class="relative aspect-[16/10] overflow-hidden"
      style={`background: radial-gradient(circle at 50% 50%, ${color}30, transparent 70%), linear-gradient(135deg, #131722 0%, #0b0d12 100%);`}
    >
      <img
        src={cartaDestacada}
        alt={cartaDestacadaAlt ?? `Carta de ${nombre}`}
        class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 h-[120%] object-contain drop-shadow-2xl group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg-card)] via-transparent to-transparent pointer-events-none"></div>
      {price?.market && (
        <div class="absolute top-3 left-3 backdrop-blur-sm bg-black/60 border border-[var(--color-border)] rounded-lg px-2.5 py-1.5 flex flex-col pointer-events-none">
          <span class="text-[9px] uppercase tracking-wider text-[var(--color-text-mute)] leading-none mb-0.5">
            TCGPlayer
          </span>
          <span class="font-[var(--font-display)] font-bold text-sm text-white leading-none">
            {fmtUSD(price.market)}
          </span>
        </div>
      )}
    </div>
  )}
  <div
    class="h-2 w-full"
    style={`background: linear-gradient(90deg, ${color}, ${color}80);`}
  ></div>
  <div class="p-6">
    <div class="flex items-start justify-between gap-3 mb-3">
      <div>
        <p class="text-xs uppercase tracking-wider text-[var(--color-text-mute)] mb-1">
          {serie}
        </p>
        <h3 class="font-[var(--font-display)] text-xl font-bold leading-tight group-hover:text-[var(--color-accent)] transition-colors">
          <a href={href} class="before:absolute before:inset-0 before:content-[''] before:z-0">
            {nombre}
          </a>
        </h3>
      </div>
      <span
        class="shrink-0 text-xs font-mono font-semibold px-2 py-1 rounded border border-[var(--color-border)] relative z-10"
        style={`color: ${color};`}
      >
        {codigo}
      </span>
    </div>

    <p class="text-sm text-[var(--color-text-dim)] leading-relaxed mb-4 line-clamp-3">
      {descripcion}
    </p>

    <div class="flex items-center justify-between text-xs text-[var(--color-text-mute)] pt-3 border-t border-[var(--color-border)]">
      <span class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
        {fecha}
      </span>
      <span class="font-semibold text-[var(--color-text-dim)]">
        {totalCartas} cartas
      </span>
    </div>

    {(tcgplayerUrl || pkmnggUrl) && (
      <div class="flex gap-2 mt-3 relative z-10">
        {tcgplayerUrl && (
          <a
            href={tcgplayerUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex-1 text-center text-[11px] font-semibold px-2 py-1.5 rounded-md bg-[var(--color-bg-elev)] border border-[var(--color-border)] text-[var(--color-text-dim)] hover:text-[var(--color-accent)] hover:border-[var(--color-accent)] transition-colors"
          >
            TCGPlayer ↗
          </a>
        )}
        {pkmnggUrl && (
          <a
            href={pkmnggUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex-1 text-center text-[11px] font-semibold px-2 py-1.5 rounded-md bg-[var(--color-bg-elev)] border border-[var(--color-border)] text-[var(--color-text-dim)] hover:text-[var(--color-accent)] hover:border-[var(--color-accent)] transition-colors"
          >
            pkmn.gg ↗
          </a>
        )}
      </div>
    )}
  </div>
</article>
