---
interface Props {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  tags?: string[];
  featured?: boolean;
}

const { href, title, description, pubDate, category, tags = [], featured = false } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('es-CO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a
  href={href}
  class={`card-hover group block rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-card)] overflow-hidden ${
    featured ? 'md:col-span-2' : ''
  }`}
>
  <div class={`p-6 md:p-7 h-full flex flex-col ${featured ? 'md:p-10' : ''}`}>
    <div class="flex flex-wrap items-center gap-2 mb-4">
      <span class="text-xs font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full bg-[var(--color-accent)] text-black">
        {category}
      </span>
      <time class="text-xs text-[var(--color-text-mute)]">{formattedDate}</time>
    </div>

    <h3
      class={`font-[var(--font-display)] font-bold leading-tight mb-3 group-hover:text-[var(--color-accent)] transition-colors ${
        featured ? 'text-2xl md:text-3xl' : 'text-xl'
      }`}
    >
      {title}
    </h3>

    <p class="text-[var(--color-text-dim)] text-sm md:text-base leading-relaxed mb-4 flex-1">
      {description}
    </p>

    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mt-auto">
        {tags.slice(0, 3).map((tag) => (
          <span class="text-xs text-[var(--color-text-mute)] bg-[var(--color-bg-elev)] px-2 py-1 rounded">
            #{tag}
          </span>
        ))}
      </div>
    )}

    <div class="mt-5 flex items-center text-sm font-medium text-[var(--color-accent)] gap-1.5">
      Leer artículo
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform">
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </div>
  </div>
</a>
