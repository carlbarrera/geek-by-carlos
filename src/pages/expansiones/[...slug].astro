---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import pricesData from '../../data/card-prices.json';

export async function getStaticPaths() {
  const expansiones = await getCollection('expansiones');
  return expansiones.map((exp) => ({
    params: { slug: exp.id },
    props: { exp },
  }));
}

const { exp } = Astro.props;
const { Content } = await render(exp);

const prices = (pricesData as any).prices ?? {};
const price = prices[exp.id];

// setApiId: pokemontcg.io for older sets, scrydex.com for newer ones (me2pt5, me3)
const setApiId =
  exp.data.cartaDestacada?.match(/pokemontcg\.io\/([^/]+)\//)?.[1] ??
  exp.data.cartaDestacada?.match(/scrydex\.com\/pokemon\/([^/-]+)-/)?.[1] ??
  null;
const pkmnggUrl = setApiId ? `https://pkmn.gg/sets/${setApiId}` : null;
const tcgplayerUrl = price?.tcgplayerUrl;

const fecha = exp.data.fechaLanzamiento.toLocaleDateString('es-CO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const fmtUSD = (n?: number) =>
  typeof n === 'number'
    ? new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 2 }).format(n)
    : '—';

const priceFetchedAt = (pricesData as any).fetchedAt
  ? new Date((pricesData as any).fetchedAt).toLocaleDateString('es-CO', { day: 'numeric', month: 'long', year: 'numeric' })
  : null;
---

<BaseLayout title={exp.data.nombre} description={exp.data.descripcion}>
  <article class="container-page py-12 md:py-16 max-w-3xl">
    <a href="/expansiones" class="inline-flex items-center gap-2 text-sm text-[var(--color-text-dim)] hover:text-[var(--color-accent)] mb-8">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
      Volver a expansiones
    </a>

    <header class="mb-10 pb-8 border-b border-[var(--color-border)]">
      <div
        class="h-2 w-24 rounded-full mb-5"
        style={`background: linear-gradient(90deg, ${exp.data.color}, ${exp.data.color}80);`}
      ></div>

      <p class="text-sm uppercase tracking-wider text-[var(--color-text-mute)] mb-2">
        {exp.data.serie} · <span class="font-mono" style={`color: ${exp.data.color};`}>{exp.data.codigo}</span>
      </p>

      <h1 class="font-[var(--font-display)] text-3xl sm:text-4xl md:text-5xl font-bold leading-tight tracking-tight mb-5">
        {exp.data.nombre}
      </h1>

      <div class="grid md:grid-cols-[1fr_220px] gap-6 items-start">
        <div>
          <p class="text-lg text-[var(--color-text-dim)] leading-relaxed mb-6">
            {exp.data.descripcion}
          </p>

          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 max-w-md">
            <div class="bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-xl p-4">
              <p class="text-xs uppercase tracking-wider text-[var(--color-text-mute)] mb-1">Lanzamiento</p>
              <p class="font-semibold text-sm">{fecha}</p>
            </div>
            <div class="bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-xl p-4">
              <p class="text-xs uppercase tracking-wider text-[var(--color-text-mute)] mb-1">Total cartas</p>
              <p class="font-semibold">{exp.data.totalCartas}</p>
            </div>
            {price?.market && (
              <div
                class="border rounded-xl p-4 col-span-2 sm:col-span-1"
                style={`background: linear-gradient(135deg, ${exp.data.color}15, var(--color-bg-card)); border-color: ${exp.data.color}40;`}
              >
                <p class="text-xs uppercase tracking-wider text-[var(--color-text-mute)] mb-1">Chase card</p>
                <p class="font-[var(--font-display)] font-bold text-lg" style={`color: ${exp.data.color};`}>
                  {fmtUSD(price.market)}
                </p>
              </div>
            )}
          </div>

          {(tcgplayerUrl || pkmnggUrl) && (
            <div class="flex flex-wrap gap-2 mt-5">
              {tcgplayerUrl && (
                <a
                  href={tcgplayerUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 text-sm font-semibold px-4 py-2 rounded-lg bg-[var(--color-bg-card)] border border-[var(--color-border)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors"
                >
                  Ver en TCGPlayer
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M7 17L17 7"></path>
                    <path d="M7 7h10v10"></path>
                  </svg>
                </a>
              )}
              {pkmnggUrl && (
                <a
                  href={pkmnggUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 text-sm font-semibold px-4 py-2 rounded-lg bg-[var(--color-bg-card)] border border-[var(--color-border)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors"
                >
                  Explorar en pkmn.gg
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M7 17L17 7"></path>
                    <path d="M7 7h10v10"></path>
                  </svg>
                </a>
              )}
            </div>
          )}
          {priceFetchedAt && price?.market && (
            <p class="text-xs text-[var(--color-text-mute)] mt-3">
              Precio actualizado: {priceFetchedAt} · fuente TCGPlayer vía pokemontcg.io
            </p>
          )}
        </div>

        {exp.data.cartaDestacada && (
          <div class="relative justify-self-center md:justify-self-end">
            <div
              class="absolute inset-0 blur-2xl opacity-50 rounded-full"
              style={`background: ${exp.data.color};`}
            ></div>
            <img
              src={exp.data.cartaDestacada}
              alt={exp.data.cartaDestacadaAlt ?? `Carta de ${exp.data.nombre}`}
              class="relative w-44 md:w-56 rounded-xl shadow-2xl shadow-black/60 rotate-2 hover:rotate-0 transition-transform duration-500"
              loading="eager"
            />
          </div>
        )}
      </div>
    </header>

    <div class="prose-custom">
      <Content />
    </div>
  </article>
</BaseLayout>
